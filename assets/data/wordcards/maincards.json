  { "text": "小兔子，你可别污蔑我。", "enabled": true },
  { "text": "你是不是又在胡思乱想?", "enabled": true },
  { "text": "我们一起变好。", "enabled": true },
  { "text": "你在做什么？", "enabled": true },
  { "text": "保护好自己。", "enabled": true },
  { "text": "照顾好自己。", "enabled": true },
  { "text": "很想吻你。", "enabled": true },
