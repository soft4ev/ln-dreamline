  { "text": "哦。", "enabled": true },
  { "text": "我爱你。", "enabled": true },
  { "text": "陪陪我。", "enabled": true },
  { "text": "陪陪你。", "enabled": true },
  { "text": "哄哄你。", "enabled": true },
